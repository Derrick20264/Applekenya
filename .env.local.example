NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# M-Pesa Configuration
# Set MPESA_ENV to 'production' when going live — also update shortcode and passkey
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey_here

# App URL for M-Pesa callbacks (used as fallback if MPESA_CALLBACK_URL is not set)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Explicit M-Pesa callback URL (use an ngrok/public URL in development for sandbox testing)
MPESA_CALLBACK_URL=https://your-ngrok-url.ngrok.io/api/mpesa/callback
